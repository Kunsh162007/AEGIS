# ── Copy this file to .env and fill in real values. NEVER commit .env. ───

# Which model backend to use for LLM narration/reasoning.
# Options: mock | auto | aimlapi | featherless | ollama
#   mock  -> whole system offline, deterministic, no keys (default).
#   auto  -> route BY TIER: reasoning agents -> AI/ML API, specialists ->
#            Featherless, fallback -> Ollama (see tier_routing in config.py).
#   <name>-> force that single provider for every agent.
# Any tier whose key is missing falls back to Ollama automatically.
MODEL_PROVIDER=mock

# Use the CrewAI + LangGraph frameworks for orchestration (production path).
# false = run the built-in framework-agnostic orchestrator (no heavy deps).
USE_FRAMEWORKS=false

# Cache LLM responses on disk so re-running a demo case costs nothing.
MODEL_CACHE=true

# ── AI/ML API (frontier reasoning: Orchestrator/Challenger/Verifier/Adjudicator)
# Get a key + $10 credit at https://aimlapi.com  (billing setup may be required)
AIMLAPI_KEY=
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1
AIMLAPI_MODEL=gpt-4o-mini

# ── Featherless AI (open-source models for specialists + coding agent)
# Get a key + $25 credit at https://featherless.ai
FEATHERLESS_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# ── Ollama (free local fallback). Install from https://ollama.com then `ollama pull llama3.1`
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

# ── Band (https://band.ai — agents + humans collaborating in shared rooms)
# 1. pip install "band-sdk[langgraph]" langchain-openai
# 2. Sign in at https://app.band.ai -> create a REMOTE AGENT named "AEGIS"
#    -> copy its agent UUID and API key here.
# 3. python -m src.band.band_agent   (then @AEGIS in any Band room)
# BAND_REST_URL / BAND_WS_URL default to Band Cloud; set only if self-hosting.
BAND_AGENT_ID=
BAND_AGENT_KEY=
BAND_TENANT_ID=bank-alpha

# Comma-separated origins allowed by the API in local dev (UI on Next dev server).
# The production deploy is single-origin and needs none of these.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Public AML benchmark dataset path (PaySim / IBM AML / Elliptic)
# Download a CSV from Kaggle and point this at it. Leave blank to use synthetic-only.
PUBLIC_DATASET_PATH=
PUBLIC_DATASET_KIND=paysim
